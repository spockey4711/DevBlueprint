# Environment variables for this project. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read secrets from the environment; never hard-code or commit them.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Runtime ---
# APP_ENV=development
# PORT=8080

# --- Database (uncomment if the project uses one) ---
# DATABASE_URL=

# --- Third-party secrets (uncomment as needed) ---
# API_KEY=
