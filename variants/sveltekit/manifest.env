# Variant manifest - sourced by bin/devblueprint. Shell key=value pairs.
VARIANT_TITLE="Web app (SvelteKit + pnpm)"
QUALITY_GATE="pnpm lint && pnpm check && pnpm test && pnpm build"
WT_CMD="pnpm wt"
COPY_LANGUAGE_NOTE="Localize user-facing copy in a dedicated i18n/content layer (e.g. Paraglide or a messages module), never as scattered string literals through the components."
# Source directories to scaffold with a .gitkeep so the layout exists from day one.
SRC_DIRS="src/routes src/lib src/lib/components src/lib/server tests/unit tests/e2e"
