# Environment variables for this SvelteKit app. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these via $env/* (12-factor); never hard-code or commit secrets.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.
#
# PUBLIC_* variables are inlined into the client bundle - treat them as
# world-readable and never put a secret behind that prefix.

# --- Runtime (server) ---
NODE_ENV=development
# Port the adapter-node server listens on (the platform usually sets PORT).
# PORT=3000
# Public origin so form actions and CSRF resolve correctly behind a proxy.
# ORIGIN=https://app.example.com

# --- Server-only secrets (uncomment if the app uses them) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# --- PUBLIC_* build-time vars (client-visible, never secret) ---
# PUBLIC_APP_NAME=DevBlueprint
