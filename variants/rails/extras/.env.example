# Environment variables for this Rails app. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these from the environment (12-factor); never hard-code or commit secrets.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Runtime ---
RAILS_ENV=development
# Signing secret for sessions and cookies. Required in production - generate one
# with `bin/rails secret` and set it in the platform's secret store, never here.
# SECRET_KEY_BASE=
# Log to stdout so a container/PaaS log aggregator can collect it.
# RAILS_LOG_TO_STDOUT=true

# --- Database (uncomment if the app uses one) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# --- Credentials (uncomment as needed) ---
# Key that decrypts config/credentials - keep it in the secret store, never commit.
# RAILS_MASTER_KEY=
