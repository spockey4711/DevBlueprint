# Environment variables for this Laravel app. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these through config() (12-factor); never call env() outside config files,
# and never hard-code or commit secrets.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Application ---
APP_NAME=Laravel
APP_ENV=local
# Generate a real key into .env with `php artisan key:generate`. Never commit it.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --- Logging ---
LOG_CHANNEL=stack

# --- Database (uncomment and fill in if the app uses one) ---
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=laravel
# DB_PASSWORD=
# On managed/serverless platforms, a single connection URL may be provided instead.
# DATABASE_URL=
