# Keep the Docker build context small and secret-free. A leaner context uploads
# and builds faster and, crucially, keeps local secrets and VCS history out of the
# image. The build stage regenerates anything below from mix.exs + the sources.

# Version control and CI
.git
.gitignore
.github

# Local environment and secrets - never ship these into an image (.env.example
# is the one tracked template, and even it is not needed inside the image).
.env
.env.*
!.env.example

# Build output and release artifacts - recompiled inside the build stage.
/_build/
/deps/
/cover/
/doc/

# Dialyzer PLTs - a build-time analysis artifact, not needed at run time.
/priv/plts/

# Digested and compiled asset output - regenerated by `mix assets.deploy`.
/priv/static/assets/
/priv/static/cache_manifest.json

# Node modules if assets use them - reinstalled in the build stage.
/assets/node_modules/

# Docs and editor / OS cruft
docs
.DS_Store
.idea
.vscode
