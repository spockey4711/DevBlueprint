# Environment variables for this Phoenix app. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these in config/runtime.exs (12-factor); never hard-code or commit secrets.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Runtime ---
MIX_ENV=prod
# Public host the endpoint is served from (used for url: [host:] and cookies).
# PHX_HOST=example.com
# Port the Phoenix endpoint listens on (the platform usually sets PORT).
# PORT=4000

# --- Secrets (uncomment and set before the release will boot) ---
# Generate with `mix phx.gen.secret`.
# SECRET_KEY_BASE=

# --- Database (uncomment if the app uses Ecto) ---
# DATABASE_URL=ecto://user:password@host:5432/dbname
# POOL_SIZE=10
