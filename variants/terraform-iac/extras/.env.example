# Environment variables for this Terraform stack. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these from a secrets manager or the environment at plan/apply time
# (never hard-code or commit provider credentials, state secrets or tfvars).
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Provider credentials (example: AWS - swap for your target cloud) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1

# --- Remote state backend (configure before any team use) ---
# TF_BACKEND_BUCKET=my-org-terraform-state
# TF_BACKEND_KEY=envs/production/terraform.tfstate
# TF_BACKEND_DYNAMODB_TABLE=terraform-state-lock

# --- Terraform inputs (TF_VAR_* map onto root-module variables) ---
# TF_VAR_environment=production
# TF_VAR_project=my-app
