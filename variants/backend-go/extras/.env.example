# Environment variables for this Go service. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these from the environment (12-factor); never hard-code or commit secrets.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Runtime ---
APP_ENV=development
# Port the HTTP server listens on (the platform usually sets PORT).
# PORT=8080

# --- Database (uncomment if the service uses one) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# Point at a pooled connection string on serverless/managed platforms.
# DATABASE_POOL_URL=

# --- Auth / third-party secrets (uncomment as needed) ---
# JWT_SECRET=
# API_KEY=
