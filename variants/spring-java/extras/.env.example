# Environment variables for this Spring Boot service. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these from the environment (12-factor); never hard-code or commit secrets.
# Spring binds them to properties (SPRING_DATASOURCE_URL -> spring.datasource.url).
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Runtime ---
SPRING_PROFILES_ACTIVE=development
# Port the HTTP server listens on (the platform usually sets it).
# SERVER_PORT=8080

# --- Database (uncomment if the service uses one) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/dbname
# SPRING_DATASOURCE_USERNAME=app
# SPRING_DATASOURCE_PASSWORD=

# --- Auth / third-party secrets (uncomment as needed) ---
# JWT_SECRET=
# API_KEY=
