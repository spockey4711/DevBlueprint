# Variant manifest - sourced by bin/devblueprint. Shell key=value pairs.
VARIANT_TITLE="Backend API (Node + Express + TypeScript)"
QUALITY_GATE="sh scripts/check-env.sh && npm run lint && npm run typecheck && npm test && npm run build"
WT_CMD="npm run wt"
COPY_LANGUAGE_NOTE="User-facing strings (API error messages, response bodies) come from a central messages/constants module, never scattered string literals."
# Source directories to scaffold with a .gitkeep so the layout exists from day one.
SRC_DIRS="src src/routes src/middleware src/services src/lib tests/unit tests/integration"
