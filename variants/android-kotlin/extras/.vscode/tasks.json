{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Quality gate",
      "detail": "Run the full quality gate - formatting, lint, types, tests and build. Do this before every commit and push.",
      "type": "shell",
      "command": "make check",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Lint",
      "detail": "Check code style and catch common mistakes.",
      "type": "shell",
      "command": "make lint",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Static analysis (detekt)",
      "detail": "Run Kotlin static analysis.",
      "type": "shell",
      "command": "make detekt",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Android Lint",
      "detail": "Run the Android lint checks.",
      "type": "shell",
      "command": "make androidlint",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run tests",
      "detail": "Run the test suite.",
      "type": "shell",
      "command": "make test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
