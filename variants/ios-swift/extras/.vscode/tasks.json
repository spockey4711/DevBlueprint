{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Quality gate",
      "detail": "Run the full quality gate - formatting, lint, types, tests and build. Do this before every commit and push.",
      "type": "shell",
      "command": "swiftformat --lint . && swiftlint --strict && swift build && swift test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Check formatting",
      "detail": "Verify the code is formatted (the gate fails on unformatted code).",
      "type": "shell",
      "command": "swiftformat --lint .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Lint",
      "detail": "Check code style and catch common mistakes.",
      "type": "shell",
      "command": "swiftlint --strict",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Build",
      "detail": "Compile and build the project.",
      "type": "shell",
      "command": "swift build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run tests",
      "detail": "Run the test suite.",
      "type": "shell",
      "command": "swift test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
