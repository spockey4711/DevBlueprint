# Environment variables for this Nuxt app. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
#
# `.env.schema` is the contract these variables must match, and the quality gate
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.
#
# Rules:
# - Server-only secrets have NO prefix (map to top-level `runtimeConfig.*`) and
#   never reach the browser.
# - NUXT_PUBLIC_* overrides `runtimeConfig.public.*`, which is shipped to the
#   browser - use it only for values safe to expose to every visitor. Nuxt reads
#   these at server start, not build time, so the same build runs everywhere.

# --- Runtime ---
NODE_ENV=development
# Host/port the Nitro server binds to (the platform usually sets these).
# HOST=0.0.0.0
# PORT=3000

# --- Public (shipped to the browser - no secrets here) ---
NUXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (server-only) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Serverless/edge deploys should point at a pooled connection string.
# DATABASE_POOL_URL=

# --- Auth / third-party secrets (server-only, uncomment as needed) ---
# AUTH_SECRET=
# API_KEY=
