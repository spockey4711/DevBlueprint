# Variant manifest - sourced by bin/devblueprint. Shell key=value pairs.
VARIANT_TITLE="Web app (Vue + Nuxt + pnpm)"
QUALITY_GATE="sh scripts/check-env.sh && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
WT_CMD="pnpm wt"
COPY_LANGUAGE_NOTE="Localize user-facing copy in a dedicated i18n layer (e.g. @nuxtjs/i18n), never as scattered string literals in templates."
# Source directories to scaffold with a .gitkeep so the Nuxt layout exists from day one.
SRC_DIRS="pages components composables layouts server/api utils assets/css tests/unit tests/e2e"
