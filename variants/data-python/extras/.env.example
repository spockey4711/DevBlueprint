# Environment variables for this data pipeline. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Read these from the environment (12-factor); never hard-code or commit secrets.
# Pull credentials from a secrets manager (Vault, AWS/GCP secret stores, the
# scheduler's secret injection) - a static value here is for local work only.
#
# `.env.schema` is the contract these variables must match, and `make check`
# fails if this file and the schema drift apart. When you add a variable, declare
# it in both places.

# --- Runtime ---
APP_ENV=development

# --- Source / warehouse (uncomment the one you use) ---
# DATABASE_URL=postgres://user:password@host:5432/warehouse?sslmode=require
# Snowflake
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# BigQuery
# BIGQUERY_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# --- Object store for inputs/outputs (uncomment as needed) ---
# Prefer an instance/workload role over static keys where the platform allows it.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# GCS_BUCKET=
