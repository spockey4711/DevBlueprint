{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Quality gate",
      "detail": "Run the full quality gate - formatting, lint, types, tests and build. Do this before every commit and push.",
      "type": "shell",
      "command": "sh scripts/check-env.sh && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Lint",
      "detail": "Check code style and catch common mistakes.",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Type-check",
      "detail": "Verify types line up across the code.",
      "type": "shell",
      "command": "pnpm typecheck",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run tests",
      "detail": "Run the test suite.",
      "type": "shell",
      "command": "pnpm test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Build",
      "detail": "Compile and build the project.",
      "type": "shell",
      "command": "pnpm build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
