{
  "name": "Backend / API (Python + uv) - DevBlueprint",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "forwardPorts": [8000],
  "postCreateCommand": "pipx install uv && bash setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "EditorConfig.EditorConfig",
        "github.vscode-github-actions"
      ]
    }
  }
}
