# Environment variables for this FastAPI service. Copy to .env and fill in.
# Only this .env.example is committed - real .env* files are gitignored.
# Load these through a settings object (e.g. Pydantic BaseSettings); never
# hard-code or commit secrets.

# --- Runtime ---
APP_ENV=development
# Host/port the ASGI server binds to (the platform usually sets PORT).
# PORT=8000

# --- Database (uncomment if the service uses one) ---
# Use an async driver, e.g. postgresql+asyncpg://user:password@host:5432/dbname
# DATABASE_URL=
# Point at a pooled connection string on serverless/managed platforms.
# DATABASE_POOL_URL=

# --- Auth / third-party secrets (server-only, uncomment as needed) ---
# SECRET_KEY=
# API_KEY=
