{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Quality gate",
      "detail": "Run the full quality gate - formatting, lint, types, tests and build. Do this before every commit and push.",
      "type": "shell",
      "command": "sh scripts/check-env.sh && ruff check . && ruff format --check . && mypy . && pytest",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Lint",
      "detail": "Check code style and catch common mistakes.",
      "type": "shell",
      "command": "ruff check .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Check formatting",
      "detail": "Verify the code is formatted (the gate fails on unformatted code).",
      "type": "shell",
      "command": "ruff format --check .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Type-check",
      "detail": "Verify types line up across the code.",
      "type": "shell",
      "command": "mypy .",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run tests",
      "detail": "Run the test suite.",
      "type": "shell",
      "command": "pytest",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
